# ============================================
# HR Copilot Chile — Variables de Entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================

# ─────────────────────────────────────────────
# AI Gateway de Vercel (Recomendado)
# 1. Ve a vercel.com/ai-gateway
# 2. Haz click en "Create Key"
# 3. Recuerda que Vercel requiere tener una tarjeta 
#    de crédito configurada para habilitar los créditos.
# ─────────────────────────────────────────────
AI_GATEWAY_API_KEY=vck_...

# ─────────────────────────────────────────────
# App Config
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="HR Copilot Chile"
NEXT_PUBLIC_APP_VERSION="1.0.0"
